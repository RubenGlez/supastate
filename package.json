{
  "name": "supastate",
  "version": "3.0.2",
  "description": "Tiny reactive engine for plain HTML and vanilla JavaScript",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "build": "rollup -c",
    "test": "jest",
    "test:w": "jest --watchAll",
    "test:c": "jest --coverage",
    "postversion": "git push && git push --tags"
  },
  "keywords": [
    "reactive",
    "reactivity",
    "vanilla",
    "vanilla-js",
    "plain-html",
    "dom",
    "state",
    "state-management",
    "proxy",
    "progressive-enhancement",
    "no-framework",
    "lightweight",
    "htmx",
    "alpine"
  ],
  "author": "RubenGlez",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.22",
    "eslint": "^10.4.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "rollup": "^4.12.0",
    "rollup-plugin-dts": "^6.1.0",
    "rollup-plugin-esbuild": "^6.1.1",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.59.4"
  },
  "engines": {
    "node": ">=16"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "preset": "ts-jest"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/RubenGlez/supastate.git"
  },
  "packageManager": "pnpm@11.1.3"
}
